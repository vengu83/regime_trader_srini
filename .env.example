ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Perplexity API — used by --research flag for pre-market news
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# ── Telegram alerts (recommended) ────────────────────────────────────────────
# 1. Create a bot via @BotFather → get TELEGRAM_BOT_TOKEN
# 2. Start a chat with your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates  to find your TELEGRAM_CHAT_ID
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Gmail alerts (optional) ───────────────────────────────────────────────────
# Use a Gmail App Password (not your real password):
# Google Account → Security → 2-Step Verification → App passwords
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=you@gmail.com
ALERT_SMTP_PASSWORD=your_16_char_app_password
ALERT_EMAIL_TO=you@gmail.com

# ── Generic webhook (Slack / Discord — optional) ──────────────────────────────
ALERT_WEBHOOK=
